{
  "name": "PRD to Planner Tasks",
  "description": "Instant cloud flow that creates Planner tasks from a JSON payload. Build this flow in Power Automate using the step-by-step instructions in SKILL.md.",
  "trigger": {
    "type": "Manually trigger a flow",
    "inputs": {
      "taskPayload": {
        "type": "Text",
        "description": "Paste JSON from exports/<name>-planner-payload.json"
      }
    }
  },
  "actions": [
    {
      "step": 1,
      "name": "Parse_JSON",
      "type": "Data Operations — Parse JSON",
      "inputs": {
        "content": "@triggerBody()['text']",
        "schema": "See references/flow-schema.md → Payload Schema"
      }
    },
    {
      "step": 2,
      "name": "Initialize_bucketMap",
      "type": "Initialize variable",
      "inputs": {
        "name": "bucketMap",
        "type": "Object",
        "value": {}
      }
    },
    {
      "step": 3,
      "name": "For_Each_Task",
      "type": "Apply to each",
      "over": "@body('Parse_JSON')?['tasks']",
      "actions": [
        {
          "step": "3a",
          "name": "Check_Bucket_Exists",
          "type": "Condition",
          "expression": "@contains(string(variables('bucketMap')), items('For_Each_Task')?['bucketName'])"
        },
        {
          "step": "3b",
          "name": "Create_Bucket_If_New",
          "type": "Planner — Create a bucket",
          "runIf": "Condition is false",
          "inputs": {
            "planId": "@body('Parse_JSON')?['planId']",
            "name": "@items('For_Each_Task')?['bucketName']"
          },
          "postAction": "Append bucket name and ID to bucketMap variable"
        },
        {
          "step": "3c",
          "name": "Create_Task",
          "type": "Planner — Create a task",
          "inputs": {
            "planId": "@body('Parse_JSON')?['planId']",
            "bucketId": "Lookup from bucketMap by items('For_Each_Task')?['bucketName']",
            "title": "@items('For_Each_Task')?['title']",
            "priority": "@items('For_Each_Task')?['priority']"
          }
        },
        {
          "step": "3d",
          "name": "Update_Task_Details",
          "type": "Planner — Update task details",
          "inputs": {
            "taskId": "@outputs('Create_Task')?['body/id']",
            "description": "@items('For_Each_Task')?['notes']"
          }
        },
        {
          "step": "3e",
          "name": "Add_Checklist_Items",
          "type": "Apply to each (nested)",
          "over": "@items('For_Each_Task')?['checklistItems']",
          "actions": [
            {
              "type": "Planner — Update task details (add checklist item)",
              "inputs": {
                "taskId": "@outputs('Create_Task')?['body/id']",
                "checklistItem": "@items('Add_Checklist_Items')"
              }
            }
          ]
        }
      ]
    }
  ]
}
